    "typeorm": "typeorm-ts-node-commonjs",
    "typeorm:migration:run": "npm run typeorm migration:run -- -d src/database/data-source.ts",
    "seed": "ts-node src/database/seed.ts",
    "seed:fresh": "ts-node src/database/seed-fresh.ts"
