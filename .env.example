# ============================================================================
# NexaFX Backend - Environment Configuration Template
# ============================================================================
# Copy this file to .env and configure all variables for your environment.
# Required variables: marked with [REQUIRED]
# Optional variables: marked with [OPTIONAL], have defaults listed
# 
# ⚠️  SECURITY: Never commit .env to version control. Update .gitignore if needed.
# ============================================================================

# --------------------------------------------------------------------------
# DATABASE CONFIGURATION [REQUIRED]
# --------------------------------------------------------------------------
# PostgreSQL connection settings. Ensure PostgreSQL is running before startup.

# PostgreSQL connection string (takes precedence over individual DB_* vars)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexafx

# Redis connection string used for cache, throttling, refresh tokens, and queues
REDIS_URL=redis://localhost:6379

# Individual database components (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nexafx

# --------------------------------------------------------------------------
# APPLICATION ENVIRONMENT [REQUIRED]
# --------------------------------------------------------------------------

# Runtime environment. Controls feature behavior, logging, and error handling.
# Values: development, staging, production
NODE_ENV=development
PORT=3000

# --------------------------------------------------------------------------
# JWT AUTHENTICATION [REQUIRED]
# --------------------------------------------------------------------------
# Secure token-based authentication using JSON Web Tokens

# Secret key for signing JWT tokens (min 32 characters recommended)
# Generate a secure key: openssl rand -base64 32
# ⚠️  SECURITY: Change in production! Different key per environment.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# How long access tokens remain valid
# Format: number + unit (ms, s, m, h, d)
# Examples: 15m (15 minutes), 1h (1 hour), 7d (7 days)
JWT_EXPIRES_IN=15m

# --------------------------------------------------------------------------
# REFRESH TOKEN CONFIGURATION [REQUIRED]
# --------------------------------------------------------------------------
# Used to obtain new access tokens after expiration

# Secret key for signing refresh tokens (min 32 characters)
# Generate: openssl rand -base64 32
# ⚠️  SECURITY: Must differ from JWT_SECRET
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-hmac-key-change-in-production-min-32-chars

# Refresh token lifespan in days
# Users can use this token to get a new access token for this duration
REFRESH_TOKEN_EXPIRES_DAYS=30

# --------------------------------------------------------------------------
# TWO-FACTOR AUTHENTICATION (2FA) [REQUIRED]
# --------------------------------------------------------------------------
# Time-based One-Time Password (TOTP) for enhanced security

# Secret key for TOTP generation (HMAC-based)
# Generate: openssl rand -base64 32
# ⚠️  SECURITY: Keep this secret and consistent across application instances
OTP_SECRET=your-super-secret-otp-hmac-key-change-in-production-min-32-chars

# How long each OTP code remains valid (in minutes)
# Typical: 5-10 minutes to balance security and UX
OTP_EXPIRES_MINUTES=10

# --------------------------------------------------------------------------
# STELLAR BLOCKCHAIN CONFIGURATION [REQUIRED]
# --------------------------------------------------------------------------
# Integration with Stellar network for cryptocurrency transactions

# Stellar network to connect to
# TESTNET: For development and testing (faucet available for XLM)
# PUBLIC: Production network (real transactions with real money)
STELLAR_NETWORK=TESTNET

# Stellar Horizon API endpoint for querying and submitting transactions
# TESTNET: https://horizon-testnet.stellar.org
# PUBLIC: https://horizon.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Base fee for Stellar transactions (in stroops, 1 XLM = 10M stroops)
# Typical: 100 stroops. Check current network minimum at Horizon
STELLAR_BASE_FEE=100

# Soroban RPC endpoint for smart contract invocation and simulation
# Example (testnet): https://horizon-testnet.stellar.org/soroban/rpc
STELLAR_SOROBAN_RPC_URL=https://horizon-testnet.stellar.org/soroban/rpc

# Default DAO contract ID on Stellar (C... string)
DAO_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Secret key for your Stellar hot wallet (for signing transactions)
# Generate an account: use Stellar Laboratory (https://stellar.org/laboratory)
# ⚠️  SECURITY: Never share this key! Store securely in environment only.
# Keep separate hot wallets for testnet and production
STELLAR_HOT_WALLET_SECRET=SBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --------------------------------------------------------------------------
# WALLET ENCRYPTION [REQUIRED]
# --------------------------------------------------------------------------
# Encrypt sensitive wallet data at rest in the database

# 64-character hexadecimal encryption key
# Generate: openssl rand -hex 32
# ⚠️  SECURITY: Store in a secure vault (AWS Secrets Manager, HashiCorp Vault)
# Changing this key will invalidate previously encrypted data
WALLET_ENCRYPTION_KEY=your-64-char-hex-key-for-wallet-encryption-change-in-production

# --------------------------------------------------------------------------
# EMAIL SERVICE (MAILGUN) [REQUIRED]
# --------------------------------------------------------------------------
# Transactional email provider for account notifications and verifications

# Mailgun API key from your Mailgun account dashboard
# Get it from: https://app.mailgun.com/app/account/security/api_keys
# ⚠️  SECURITY: Treat as a secret; rotate periodically
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Domain configured and verified in your Mailgun account
# Example: mail.nexafx.com or mg.nexafx.com
# Must be verified before sending emails
MAILGUN_DOMAIN=mail.nexafx.com

# Sender email address for all transactional emails
# Must be from the verified Mailgun domain
# Example: noreply@mail.nexafx.com
MAILGUN_FROM_EMAIL=noreply@mail.nexafx.com

# Display name shown in email "From" field
# Example: "NexaFX Support <noreply@nexafx.com>"
MAILGUN_FROM_NAME=NexaFX

# Skip actual email sending (useful for local development/testing)
# Set to true locally to prevent sending real emails during development
SKIP_EMAIL_SENDING=false

# --------------------------------------------------------------------------
# FRONTEND CONFIGURATION [REQUIRED]
# --------------------------------------------------------------------------
# Used for CORS, email links, and OAuth redirects

# Frontend application URL
# Used to generate links in emails, validate CORS requests, OAuth redirects
# Development: http://localhost:3001
# Production: https://app.nexafx.com
FRONTEND_URL=http://localhost:3001

# --------------------------------------------------------------------------
# RATE LIMITING [REQUIRED]
# --------------------------------------------------------------------------
# Throttle API requests to prevent abuse and DoS attacks

# Time window in seconds for rate limit bucket
# Combined with THROTTLE_LIMIT to define rate (e.g., 100 requests per 60 seconds)
THROTTLE_TTL=60

# Maximum requests allowed per THROTTLE_TTL window (for general endpoints)
# Example: 100 requests per 60 seconds
THROTTLE_LIMIT=100

# Maximum authentication attempts per THROTTLE_TTL window
# Stricter limit for login/register routes (brute-force protection)
THROTTLE_AUTH_LIMIT=5

# Brute force lockout duration in minutes
# After AUTH_LOCKOUT_MAX_ATTEMPTS failed OTP attempts, user is locked for this duration
AUTH_LOCKOUT_DURATION_MINUTES=15

# --------------------------------------------------------------------------
# EXCHANGE RATES PROVIDER [REQUIRED]
# --------------------------------------------------------------------------
# Service for fetching current real-time currency exchange rates

# Provider API base URL
# Default: https://api.exchangerate.host (free, no key required)
# Alternative: https://api.exchangerate.org or your own service
EXCHANGE_RATES_PROVIDER_BASE_URL=https://api.exchangerate.host

# API key for rate provider (if required)
# Leave blank if provider doesn't require authentication
# Some providers require a key for higher rate limits or premium features
EXCHANGE_RATES_PROVIDER_API_KEY=

# Request timeout in milliseconds
# If provider doesn't respond within this time, request fails
# Set based on provider performance and network conditions
EXCHANGE_RATES_PROVIDER_TIMEOUT_MS=5000

# How long to cache exchange rates (in seconds)
# Caching reduces API calls and improves response time
# 60s = 1 minute. Adjust based on rate update frequency requirements
EXCHANGE_RATES_CACHE_TTL_SECONDS=60

# Maximum number of rate pairs to cache in memory
# Protects against unlimited memory growth
# ~1000 covers most common currency pairs
EXCHANGE_RATES_CACHE_MAX_SIZE=1000

# --------------------------------------------------------------------------
# QUEUE DASHBOARD [REQUIRED FOR ADMIN OPERATIONS]
# --------------------------------------------------------------------------
# Basic auth credentials for Bull Board at /admin/queues.
QUEUE_DASHBOARD_USER=admin
QUEUE_DASHBOARD_PASSWORD=change-me

# --------------------------------------------------------------------------
# FIREBASE CLOUD MESSAGING [REQUIRED]
# --------------------------------------------------------------------------
# Service account details for sending push notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# Replace actual newlines with \n for the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgk...-----END PRIVATE KEY-----\n"

# ============================================================================
# NOTES & TIPS
# ============================================================================
#
# 1. REQUIRED vs OPTIONAL:
#    - All variables listed here should be configured before deployment
#    - Some have sensible defaults (noted in comments)
#
# 2. SECURITY:
#    - Use strong random values for all SECRET/KEY variables
#    - Rotate secrets in production periodically
#    - Never commit .env to git (should be in .gitignore)
#    - Use a secrets manager (AWS Secrets Manager, HashiCorp Vault) in production
#
# 3. ENVIRONMENT-SPECIFIC:
#    - Create separate .env.development, .env.staging, .env.production
#    - Load appropriate file based on NODE_ENV
#    - Different values for secrets across environments (DO NOT reuse in prod!)
#
# 4. TESTING:
#    - Create .env.test for running test suite
#    - Use test database, test API keys, mock external services
#
# 5. GENERATING SECURE VALUES:
#    Generate secrets with: openssl rand -base64 32 (or -hex for hex format)
#    Generate encryption keys: openssl rand -hex 32
#
# 6. VERIFICATION:
#    After setting up, verify configuration works:
#    - Run health check: curl http://localhost:3000/health
#    - Check logs for connection errors
#    - Test database connection: npm run test
#
# ============================================================================

DATABASE_URL=
ALLOWED_ORIGINS=

# --------------------------------------------------------------------------
# JWT AUTHENTICATION [REQUIRED]
# --------------------------------------------------------------------------
# Secure token-based authentication using JSON Web Tokens

# Secret key for signing JWT tokens (min 32 characters recommended)
# Generate a secure key: openssl rand -base64 32
# ⚠️  SECURITY: Change in production! Different key per environment.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# How long access tokens remain valid
# Format: number + unit (ms, s, m, h, d)
# Examples: 15m (15 minutes), 1h (1 hour), 7d (7 days)
JWT_EXPIRES_IN=15m

# --------------------------------------------------------------------------
# REFRESH TOKEN CONFIGURATION [REQUIRED]
# --------------------------------------------------------------------------
# Used to obtain new access tokens after expiration

# Secret key for signing refresh tokens (min 32 characters)
# Generate: openssl rand -base64 32
# ⚠️  SECURITY: Must differ from JWT_SECRET
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-hmac-key-change-in-production-min-32-chars

# Refresh token lifespan in days
# Users can use this token to get a new access token for this duration
REFRESH_TOKEN_EXPIRES_DAYS=30

# --------------------------------------------------------------------------
# TWO-FACTOR AUTHENTICATION (2FA) [REQUIRED]
# --------------------------------------------------------------------------
# Time-based One-Time Password (TOTP) for enhanced security

# Secret key for TOTP generation (HMAC-based)
# Generate: openssl rand -base64 32
# ⚠️  SECURITY: Keep this secret and consistent across application instances
OTP_SECRET=your-super-secret-otp-hmac-key-change-in-production-min-32-chars

# How long each OTP code remains valid (in minutes)
# Typical: 5-10 minutes to balance security and UX
OTP_EXPIRES_MINUTES=10

